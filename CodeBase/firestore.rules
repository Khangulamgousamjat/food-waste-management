rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── LISTINGS ──────────────────────────────────────────
    match /listings/{listingId} {

      // Any logged-in user can read listings
      allow read: if request.auth != null;

      // Any logged-in user can create a listing
      // (role check removed — simpler and avoids get() permission errors)
      allow create: if request.auth != null;

      // Update allowed if:
      //   1. Admin email
      //   2. The donor who owns the listing (any field update)
      //   3. Any logged-in user can claim (set status=claimed + claimedBy)
      allow update: if request.auth != null && (
        request.auth.token.email == "Gousk2004@gmail.com" ||
        request.auth.uid == resource.data.donorId ||
        (
          request.resource.data.status == 'claimed' &&
          request.resource.data.claimedBy == request.auth.uid
        )
      );

      // Only donor or admin can delete
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.donorId ||
        request.auth.token.email == "Gousk2004@gmail.com"
      );
    }

    // ── USERS ─────────────────────────────────────────────
    match /users/{userId} {

      // Any logged-in user can read profiles (for leaderboard, roles)
      allow read: if request.auth != null;

      // Users can update their own profile; admin can update anyone
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == "Gousk2004@gmail.com"
      );

      // Any logged-in user can update points field on any user doc
      // (needed when recipient claims food and awards donor points)
      allow update: if request.auth != null;
    }

    // ── ANALYTICS / OTHER ─────────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
