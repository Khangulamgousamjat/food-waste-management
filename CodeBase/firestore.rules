rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /listings/{listingId} {
      // Anyone logged in can read listings
      allow read: if request.auth != null;
      
      // Only donors can create listings
      allow create: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'donor';
      
      // Update logic
      allow update: if request.auth != null && (
        // Admin override
        request.auth.token.email == "Gousk2004@gmail.com" ||
        // Donors can update their own listings
        request.auth.uid == resource.data.donorId ||
        // Recipients can claim listings (update status and claimedBy)
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'recipient' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'claimedBy']) &&
          request.resource.data.status == 'claimed' &&
          request.resource.data.claimedBy == request.auth.uid
        )
      );

      // Only the donor or admin can delete their own listing
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.donorId || 
        request.auth.token.email == "Gousk2004@gmail.com"
      );
    }

    match /users/{userId} {
      // Anyone logged in can read user profiles (needed for leaderboards/roles)
      allow read: if request.auth != null;
      
      // Users can write their own profile, or admin can
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == "Gousk2004@gmail.com"
      );

      // Allow recipients to increment a donor's points when claiming food
      allow update: if request.auth != null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']);
    }
  }
}
